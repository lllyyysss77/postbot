{
  "name": "PostBot",
  "displayName": "PostBot 内容同步助手",
  "version": "1.2.2",
  "description": "PostBot 内容同步助手",
  "author": "GitCoffee Team @GitCoffee",
  "scripts": {
    "dev": "plasmo dev",
    "build": "bash -c 'plasmo build && cp LICENSE README.md build/chrome-mv3-prod/ && for arg in \"$@\"; do if [ \"$arg\" = \"--zip\" ]; then cd build/chrome-mv3-prod && zip -r ../chrome-mv3-prod.zip .; fi; done' --",
    "package": "plasmo build && cp LICENSE README.md build/chrome-mv3-prod/ && plasmo package"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@gitcoffee/api": "^1.0.0",
    "@gitcoffee/auth": "^1.0.0",
    "@gitcoffee/browser": "^1.0.0",
    "@gitcoffee/postbot-api": "^1.0.0",
    "@gitcoffee/postbot-actions": "^1.0.0",
    "@gitcoffee/postbot-background": "^1.0.0",
    "@gitcoffee/postbot-content-adapter": "^1.0.0",
    "@gitcoffee/postbot-content-reader": "^1.0.0",
    "@gitcoffee/postbot-content-services": "^1.0.0",
    "@gitcoffee/postbot-content-ui": "^1.0.0",
    "@gitcoffee/postbot-events": "^1.0.0",
    "@gitcoffee/postbot-media": "^1.0.0",
    "@gitcoffee/postbot-plugin-engine": "^1.0.0",
    "@gitcoffee/postbot-stores": "^1.0.0",
    "@gitcoffee/postbot-utils": "^1.0.0",
    "@gitcoffee/i18n": "^1.0.0",
    "@gitcoffee/postbot-publish-engine": "^1.0.0",
    "@gitcoffee/postbot-publisher-cn": "^1.0.0",
    "@gitcoffee/postbot-publisher-debug": "^1.0.0",
    "@gitcoffee/postbot-publisher-it": "^1.0.0",
    "@gitcoffee/postbot-publisher-industry": "^1.0.0",
    "@gitcoffee/postbot-sidepanel-ui": "^1.0.0",
    "@gitcoffee/postbot-tabs": "^1.0.0",
    "@gitcoffee/storage": "^1.0.0",
    "@gitcoffee/store": "^1.0.0",
    "@mozilla/readability": "^0.6.0",
    "@plasmohq/storage": "^1.11.0",
    "ant-design-vue": "^4.2.6",
    "dayjs": "^1.11.13",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "plasmo": "0.90.5",
    "vue": "^3.5.26"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.4.0",
    "@types/chrome": "^0.0.268",
    "@types/node": "^22.10.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.45",
    "prettier": "^3.4.2",
    "stream-browserify": "^3.0.0",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.7.2"
  },
  "manifest": {
    "host_permissions": [
      "https://*/*",
      "http://127.0.0.1/*",
      "http://localhost/*"
    ],
    "permissions": [
      "tabs",
      "commands",
      "contextMenus",
      "clipboardRead",
      "background",
      "scripting",
      "activeTab",
      "tabGroups",
      "sidePanel",
      "storage",
      "downloads"
    ]
  }
}
